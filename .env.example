# Copy to .env and fill in your keys
# .env is gitignored — never commit real keys

GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional: Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: LangSmith tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
